# ============================================
# My Control Center - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# On Cloudflare Pages these are set in the dashboard or wrangler.toml.

# ─── Authentication ───────────────────────────────────────────────────────────
# Password that protects your dashboard login page.
MCC_PASSWORD=change-me-to-a-strong-password

# Secret used to sign session cookies (HMAC-SHA256).
# Use a different value from MCC_PASSWORD.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
MCC_COOKIE_SIGNING_SECRET=change-me-to-a-random-secret

# ─── API base ─────────────────────────────────────────────────────────────────
# Keep as /api — Next.js routes all API calls through its own edge functions.
NEXT_PUBLIC_API_BASE=/api

# ─── VPS Agent Bridge ─────────────────────────────────────────────────────────
# These tell the dashboard where to find the MCC bridge (bridge.py).
#
# Running the dashboard ON your VPS (recommended — no tunnel needed):
#   Use localhost — the bridge runs on the same machine.
MCC_VPS_SSE_URL=http://localhost:8081/chat/stream
MCC_VPS_CONNECT_URL=http://localhost:8081/agents/connect
MCC_VPS_HEARTBEAT_URL=http://localhost:8081/agents/heartbeat
MCC_VPS_SCAN_URL=http://localhost:8081/agents/scan

# Running the dashboard on Cloudflare Pages (pointing directly at VPS):
#   Replace with your domain/IP — no Cloudflare Tunnel needed.
# MCC_VPS_SSE_URL=https://agents.yourdomain.com/chat/stream
# MCC_VPS_CONNECT_URL=https://agents.yourdomain.com/agents/connect
# MCC_VPS_HEARTBEAT_URL=https://agents.yourdomain.com/agents/heartbeat
# MCC_VPS_SCAN_URL=https://agents.yourdomain.com/agents/scan

# ─── Runner Token (optional) ──────────────────────────────────────────────────
# Shared secret for the VPS bridge to push results back via /api/agents/ingest.
# MCC_RUNNER_TOKEN=your-secret-token-here

# ─── Cloudflare bindings (production Cloudflare Pages only) ───────────────────
# Set automatically by Cloudflare — do not set these locally.
# D1_DATABASE_ID=...
# KV_NAMESPACE_ID=...

