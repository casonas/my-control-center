# ============================================
# My Control Center - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# ─── Authentication ───
# This password protects your dashboard
# IMPORTANT: Change this to a strong password!
MCC_PASSWORD=change-me-to-a-strong-password

# ─── API Configuration ───
# For local development, use /api
# For production with external AI, use your domain (e.g., https://api.yourdomain.com)
NEXT_PUBLIC_API_BASE=/api

# ─── Optional: OpenAI Integration ───
# If you want to use OpenAI for your agents, add your API key here
# Get one from https://platform.openai.com
# OPENAI_API_KEY=sk-...

# ─── Optional: Custom AI Backend ───
# If you're running your own AI service (like OpenClaw)
# Set this to your service URL
# AI_BACKEND_URL=http://localhost:8080

# ─── VPS Agent Endpoints ───
# Set these to connect agents to your OpenClaw VPS
# MCC_VPS_SSE_URL=https://api.yourdomain.com/chat/stream
# MCC_VPS_CONNECT_URL=https://api.yourdomain.com/agents/connect
# MCC_VPS_HEARTBEAT_URL=https://api.yourdomain.com/agents/heartbeat
# MCC_VPS_SCAN_URL=https://api.yourdomain.com/agents/scan
# MCC_VPS_STATUS_URL=https://api.yourdomain.com/status

# ─── Runner Token ───
# Shared secret for VPS agents to push results back (ingest, complete)
# MCC_RUNNER_TOKEN=your-secret-token-here

# ─── Optional: Database (for production on Cloudflare) ───
# These are automatically set by Cloudflare Pages when you deploy
# Don't set these locally - they're only for production
# D1_DATABASE_ID=...
# KV_NAMESPACE_ID=...
# R2_BUCKET_NAME=...
