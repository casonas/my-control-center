# Caddyfile — automatic HTTPS reverse proxy for my-control-center.com
#
# Architecture:
#   Cloudflare Pages (dashboard) → api.my-control-center.com  → OpenClaw Gateway :18789
#                                → bridge.my-control-center.com → MCC Bridge     :8081
#
# Caddy handles SSL cert renewal automatically (Let's Encrypt).
# No certbot, no cronjobs, no manual renewal needed.
#
# Install Caddy:
#   sudo apt install -y debian-keyring debian-archive-keyring apt-transport-https curl
#   curl -1sLf 'https://dl.cloudflare.com/caddy/stable/gpg.key' | sudo gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg
#   curl -1sLf 'https://dl.cloudflare.com/caddy/stable/debian.deb.txt' | sudo tee /etc/apt/sources.list.d/caddy-stable.list
#   sudo apt update && sudo apt install caddy
#
# Deploy:
#   sudo cp ~/my-control-center/vps/Caddyfile /etc/caddy/Caddyfile
#   sudo systemctl reload caddy
#
# DNS (Cloudflare): A records for api + bridge → VPS IP (proxied OK).
#
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenClaw Gateway API ─────────────────────────────────────────────────────
api.my-control-center.com {
    reverse_proxy localhost:18789

    # CORS headers for Cloudflare Pages dashboard
    header {
        Access-Control-Allow-Origin "https://my-control-center.pages.dev"
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization, X-CSRF-Token"
        Access-Control-Allow-Credentials "true"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
    }

    # Handle CORS preflight
    @preflight method OPTIONS
    respond @preflight 204
}

# ── Bridge Service (SSE streaming) ───────────────────────────────────────────
bridge.my-control-center.com {
    reverse_proxy localhost:8081 {
        # Disable response buffering so SSE chunks arrive immediately
        flush_interval -1
        # Strip upstream CORS headers — Caddy sets the authoritative ones below
        header_down -Access-Control-Allow-Origin
        header_down -Access-Control-Allow-Methods
        header_down -Access-Control-Allow-Headers
    }

    # CORS headers for Cloudflare Pages dashboard
    header {
        Access-Control-Allow-Origin "https://my-control-center.pages.dev"
        Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization, X-Agent-Id, X-Agent-Session, X-Collab-Agents, X-Request-Id, X-CSRF"
        Access-Control-Allow-Credentials "true"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
    }

    # Handle CORS preflight
    @preflight method OPTIONS
    respond @preflight 204
}
